# --- Next.js app (Vercel) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/odoai
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
APINOW_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
APP_URL=https://your-app.vercel.app
CRON_SECRET=some_random_secret

# Telegram: private DM subscription gate (new chats get subscriptionActive=false on first insert)
# TELEGRAM_REQUIRE_SUBSCRIPTION=true
# Comma-separated Telegram @usernames that bypass the gate (default: cdolinski)
# TELEGRAM_ADMIN_USERNAMES=cdolinski

# Optional: IANA tz for Chat Future "now" / horizon end (default America/New_York)
# FORECAST_TZ=America/Sao_Paulo

# QMD service (Railway)
QMD_URL=https://your-qmd-service.up.railway.app
QMD_API_KEY=shared_secret_between_vercel_and_railway
